  objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

  <changeSet id="1776913763345-1" author="CanhPC">
    <preConditions onFail="MARK_RAN">
      <not><tableExists tableName="login_history" schemaName="auth"/></not>
    </preConditions>
    <createTable schemaName="auth" tableName="login_history">
      <column name="id" type="BIGINT">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_login_history"/>
      </column>
      <column name="system_user_id" type="BIGINT"/>
      <column name="device_id" type="VARCHAR(255)"/>
      <column name="country_iso_code" type="VARCHAR(20)"/>
      <column name="user_id" type="BIGINT"/>
      <column name="ip_address" type="VARCHAR(45)"/>
      <column name="country" type="VARCHAR(100)"/>
      <column name="city" type="VARCHAR(100)"/>
      <column name="latitude" type="DOUBLE"/>
      <column name="longitude" type="DOUBLE"/>
      <column name="approx_location" type="VARCHAR(255)"/>
      <column name="device_type" type="VARCHAR(20)"/>
      <column name="os" type="VARCHAR(100)"/>
      <column name="browser" type="VARCHAR(100)"/>
      <column name="user_agent" type="VARCHAR(500)"/>
      <column name="channel" type="VARCHAR(20)"/>
      <column name="login_time" type="DATETIME">
        <constraints nullable="false"/>
      </column>
      <column name="request_id" type="VARCHAR(100)"/>
      <column name="is_trusted_device" type="BOOLEAN"/>
      <column name="is_new_device" type="BOOLEAN"/>
      <column name="is_vpn" type="BOOLEAN"/>
      <column name="risk_score" type="INT"/>
      <column name="status" type="VARCHAR(20)"/>
      <column name="failure_reason" type="VARCHAR(255)"/>
    </createTable>
  </changeSet>


  <changeSet id="1776913763345-13" author="CanhPC">
    <preConditions onFail="MARK_RAN">
      <not><foreignKeyConstraintExists foreignKeyName="FK_LOGIN_HISTORY_ON_USER" schemaName="auth"/></not>
    </preConditions>
    <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="login_history" baseTableSchemaName="auth"
                             constraintName="FK_LOGIN_HISTORY_ON_USER" referencedColumnNames="id"
                             referencedTableName="users" referencedTableSchemaName="auth"/>
    <addForeignKeyConstraint baseColumnNames="system_user_id" baseTableName="login_history" baseTableSchemaName="auth"
                             constraintName="FK_LOGIN_HISTORY_ON_SYSTEM_USER" referencedColumnNames="id"
                             referencedTableName="system_users" referencedTableSchemaName="auth"/>
  </changeSet>


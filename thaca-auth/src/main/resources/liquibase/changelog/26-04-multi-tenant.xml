<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="2026-04-26-multi-tenant-1" author="CanhPC">
        <createSequence sequenceName="plan_seq" schemaName="auth" startValue="1" incrementBy="1"/>
        <createTable tableName="plans" schemaName="auth">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(50)"/>
            <column name="max_users" type="INTEGER"/>
            <column name="status" type="VARCHAR(50)" defaultValue="ACTIVE"/>
            <column name="created_by" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_by" type="VARCHAR(50)"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createSequence sequenceName="tenant_seq" schemaName="auth" startValue="1" incrementBy="1"/>
        <createTable tableName="tenants" schemaName="auth">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="domain" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(50)" defaultValue="ACTIVE"/>
            <column name="plan_id" type="BIGINT"/>
            <column name="plan_type" type="VARCHAR(50)"/>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="contact_email" type="VARCHAR(255)"/>
            <column name="logo_url" type="VARCHAR(255)"/>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0"/>
            <column name="created_by" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_by" type="VARCHAR(50)"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="plan_id" baseTableName="tenants" baseTableSchemaName="auth"
                                 constraintName="fk_tenants_plan_id" referencedColumnNames="id"
                                 referencedTableName="plans" referencedTableSchemaName="auth"/>

        <loadData file="liquibase/data/plan.csv"
                  separator=";"
                  tableName="plans"
                  schemaName="auth">
            <column name="id" type="NUMERIC"/>
            <column name="code" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="type" type="STRING"/>
            <column name="max_users" type="NUMERIC"/>
            <column name="status" type="STRING"/>
            <column name="created_by" type="STRING"/>
            <column name="created_at" type="DATE"/>
        </loadData>

        <loadData file="liquibase/data/tenant.csv"
                  separator=";"
                  tableName="tenants"
                  schemaName="auth">
            <column name="id" type="NUMERIC"/>
            <column name="code" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="domain" type="STRING"/>
            <column name="status" type="STRING"/>
            <column name="plan_id" type="NUMERIC"/>
            <column name="plan_type" type="STRING"/>
            <column name="created_by" type="STRING"/>
            <column name="created_at" type="DATE"/>
            <column name="updated_by" type="STRING"/>
            <column name="updated_at" type="DATE"/>
        </loadData>
    </changeSet>

    <changeSet id="2026-04-26-multi-tenant-2" author="CanhPC">
        <addColumn tableName="users" schemaName="auth">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="users" baseTableSchemaName="auth"
                                 constraintName="fk_users_tenant_id" referencedColumnNames="id"
                                 referencedTableName="tenants" referencedTableSchemaName="auth"/>

        <addColumn tableName="roles" schemaName="auth">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1"/>
            <column name="created_by" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_by" type="VARCHAR(50)"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="roles" baseTableSchemaName="auth"
                                 constraintName="fk_roles_tenant_id" referencedColumnNames="id"
                                 referencedTableName="tenants" referencedTableSchemaName="auth"/>

        <addColumn tableName="permissions" schemaName="auth">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1"/>
            <column name="created_by" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_by" type="VARCHAR(50)"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="permissions" baseTableSchemaName="auth"
                                 constraintName="fk_permissions_tenant_id" referencedColumnNames="id"
                                 referencedTableName="tenants" referencedTableSchemaName="auth"/>

        <addColumn tableName="system_users" schemaName="auth">
            <column name="tenant_id" type="BIGINT"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="system_users" baseTableSchemaName="auth"
                                 constraintName="fk_sys_users_tenant_id" referencedColumnNames="id"
                                 referencedTableName="tenants" referencedTableSchemaName="auth"/>

        <addColumn tableName="system_credentials" schemaName="auth">
            <column name="tenant_id" type="BIGINT"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="system_credentials" baseTableSchemaName="auth"
                                 constraintName="fk_sys_cred_tenant_id" referencedColumnNames="id"
                                 referencedTableName="tenants" referencedTableSchemaName="auth"/>

        <addColumn tableName="login_history" schemaName="auth">
            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1"/>
            <column name="created_by" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_by" type="VARCHAR(50)"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="tenant_id" baseTableName="login_history" baseTableSchemaName="auth"
                                 constraintName="fk_login_hist_tenant_id" referencedColumnNames="id"
                                 referencedTableName="tenants" referencedTableSchemaName="auth"/>
    </changeSet>

    <changeSet id="load-data-multi-tenant" author="CanhPC">
        <loadData file="liquibase/data/permission.csv" separator=";" tableName="permissions" schemaName="auth">
            <column name="code" type="string"/>
            <column name="description" type="string"/>
            <column name="tenant_id" type="numeric"/>
        </loadData>

        <loadData file="liquibase/data/role.csv" separator=";" tableName="roles" schemaName="auth">
            <column name="code" type="string"/>
            <column name="description" type="string"/>
            <column name="tenant_id" type="numeric"/>
        </loadData>

        <loadData file="liquibase/data/user.csv" separator=";" tableName="users" schemaName="auth">
            <column name="id" type="numeric"/>
            <column name="username" type="string"/>
            <column name="password" type="string"/>
            <column name="is_activated" type="boolean"/>
            <column name="is_locked" type="boolean"/>
            <column name="email" type="string"/>
            <column name="tenant_id" type="numeric"/>
        </loadData>

        <loadData file="liquibase/data/system_user.csv" separator=";" tableName="system_users" schemaName="auth">
            <column name="id" type="numeric"/>
            <column name="fullname" type="string"/>
            <column name="email" type="string"/>
            <column name="is_activated" type="boolean"/>
            <column name="is_locked" type="boolean"/>
            <column name="is_super_admin" type="boolean"/>
            <column name="tenant_id" type="numeric"/>
        </loadData>

        <loadData file="liquibase/data/system_credential.csv" separator=";" tableName="system_credentials" schemaName="auth">
            <column name="username" type="string"/>
            <column name="password" type="string"/>
            <column name="system_user_id" type="numeric"/>
        </loadData>

        <loadData file="liquibase/data/role_permissions.csv" separator=";" tableName="role_permissions" schemaName="auth">
            <column name="role_code" type="string"/>
            <column name="permission_code" type="string"/>
        </loadData>

        <loadData file="liquibase/data/system_credential_roles.csv" separator=";" tableName="system_credential_roles" schemaName="auth">
            <column name="credential_id" type="string"/>
            <column name="role_code" type="string"/>
        </loadData>
    </changeSet>

</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd">

    <changeSet id="1761551503149-1" author="CanhPC">
        <createSequence incrementBy="1" sequenceName="user_seq" startValue="3" />
    </changeSet>

    <changeSet id="1761551503149-2" author="CanhPC">
        <createTable tableName="permissions">
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_permissions" />
            </column>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="TIMESTAMP" />
            <column name="updated_by" type="VARCHAR(255)" />
            <column name="updated_at" type="TIMESTAMP" />
            <column name="type" type="VARCHAR(20)">
                <constraints nullable="false" />
            </column>
            <column name="description" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="module" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="method" type="VARCHAR(50)" />
            <column name="path_pattern" type="VARCHAR(255)" />
            <column name="is_global" type="BOOLEAN">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1761551503149-3" author="CanhPC">
        <createTable tableName="roles">
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_roles" />
            </column>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="TIMESTAMP" />
            <column name="updated_by" type="VARCHAR(255)" />
            <column name="updated_at" type="TIMESTAMP" />
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="description" type="VARCHAR(255)" />
        </createTable>
    </changeSet>

    <changeSet id="1761551503149-4" author="CanhPC">
        <createTable tableName="role_permissions">
            <column name="permission_code" type="VARCHAR(50)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_role_permissions" />
            </column>
            <column name="role_code" type="VARCHAR(50)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_role_permissions" />
            </column>
            <column name="created_by" type="VARCHAR(255)" />
            <column name="created_at" type="TIMESTAMP" />
            <column name="updated_by" type="VARCHAR(255)" />
            <column name="updated_at" type="TIMESTAMP" />
        </createTable>
    </changeSet>

    <changeSet id="1761551503149-5" author="CanhPC">
        <createTable tableName="users">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users" />
            </column>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="TIMESTAMP" />
            <column name="updated_by" type="VARCHAR(255)" />
            <column name="updated_at" type="TIMESTAMP" />
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" />
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" />
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="activated" type="BOOLEAN">
                <constraints nullable="false" />
            </column>
            <column name="is_locked" type="BOOLEAN">
                <constraints nullable="false" />
            </column>
            <column name="is_global" type="BOOLEAN">
                <constraints nullable="false" />
            </column>
            <column name="refresh_token" type="TEXT" />
        </createTable>
    </changeSet>

    <changeSet id="1761551503149-6" author="CanhPC">
        <createTable tableName="user_roles">
            <column name="role_code" type="VARCHAR(50)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_roles" />
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_roles" />
            </column>
            <column name="created_by" type="VARCHAR(255)" />
            <column name="created_at" type="TIMESTAMP" />
            <column name="updated_by" type="VARCHAR(255)" />
            <column name="updated_at" type="TIMESTAMP" />
        </createTable>
    </changeSet>

    <changeSet id="1761551503149-7" author="CanhPC">
        <createTable tableName="user_permission">
            <column name="id" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_permission" />
            </column>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="TIMESTAMP" />
            <column name="updated_by" type="VARCHAR(255)" />
            <column name="updated_at" type="TIMESTAMP" />
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="permission_code" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
            <column name="action" type="VARCHAR(255)">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1761551503149-8" author="CanhPC">
        <addUniqueConstraint columnNames="username" constraintName="uc_users_username" tableName="users" />
        <addUniqueConstraint columnNames="email" constraintName="uc_users_email" tableName="users" />
    </changeSet>

    <changeSet id="1761551503149-9" author="CanhPC">
        <addForeignKeyConstraint
            baseColumnNames="permission_code" baseTableName="user_permission"
            constraintName="fk_user_permission_on_permission_code"
            referencedColumnNames="code" referencedTableName="permissions" />
    </changeSet>

    <changeSet id="1761551503149-10" author="CanhPC">
        <addForeignKeyConstraint
            baseColumnNames="permission_code" baseTableName="role_permissions"
            constraintName="fk_rolper_on_permission"
            referencedColumnNames="code" referencedTableName="permissions" />
    </changeSet>

    <changeSet id="1761551503149-11" author="CanhPC">
        <addForeignKeyConstraint
            baseColumnNames="role_code" baseTableName="role_permissions"
            constraintName="fk_rolper_on_role"
            referencedColumnNames="code" referencedTableName="roles" />
    </changeSet>

    <changeSet id="1761551503149-12" author="CanhPC">
        <addForeignKeyConstraint
            baseColumnNames="role_code" baseTableName="user_roles"
            constraintName="fk_userol_on_role"
            referencedColumnNames="code" referencedTableName="roles" />
    </changeSet>

    <changeSet id="1761551503149-13" author="CanhPC">
        <addForeignKeyConstraint
            baseColumnNames="user_id" baseTableName="user_roles"
            constraintName="fk_userol_on_user"
            referencedColumnNames="id" referencedTableName="users" />
    </changeSet>

    <changeSet id="1761551503149-14" author="CanhPC">
        <addForeignKeyConstraint
            baseColumnNames="user_id" baseTableName="user_permission"
            constraintName="fk_user_permission_on_user_id"
            referencedColumnNames="id" referencedTableName="users" />
    </changeSet>

    <changeSet id="load-data-permissions" author="CanhPC">
        <loadData file="liquibase/data/permission.csv" separator=";" tableName="permissions">
            <column name="code" type="string" />
            <column name="type" type="string" />
            <column name="description" type="string" />
            <column name="module" type="string" />
            <column name="method" type="string" />
            <column name="path_pattern" type="string" />
            <column name="is_global" type="boolean" />
            <column name="created_by" type="string" />
            <column name="created_at" type="timestamp" />
            <column name="updated_by" type="string" />
            <column name="updated_at" type="timestamp" />
        </loadData>
    </changeSet>

    <changeSet id="load-data-roles" author="CanhPC">
        <loadData file="liquibase/data/role.csv" separator=";" tableName="roles">
            <column name="code" type="string" />
            <column name="name" type="string" />
            <column name="description" type="string" />
            <column name="created_by" type="string" />
            <column name="created_at" type="timestamp" />
            <column name="updated_by" type="string" />
            <column name="updated_at" type="timestamp" />
        </loadData>
    </changeSet>

    <changeSet id="load-data-users" author="CanhPC">
        <loadData file="liquibase/data/user.csv" separator=";" tableName="users">
            <column name="id" type="numeric" />
            <column name="username" type="string" />
            <column name="password" type="string" />
            <column name="activated" type="boolean" />
            <column name="is_locked" type="boolean" />
            <column name="is_global" type="boolean" />
            <column name="email" type="string" />
            <column name="created_by" type="string" />
            <column name="created_at" type="timestamp" />
            <column name="updated_by" type="string" />
            <column name="updated_at" type="timestamp" />
        </loadData>
    </changeSet>

    <changeSet id="load-data-user-roles" author="CanhPC">
        <loadData file="liquibase/data/user_roles.csv" separator=";" tableName="user_roles">
            <column name="user_id" type="numeric" />
            <column name="role_code" type="string" />
            <column name="created_by" type="string" />
            <column name="created_at" type="timestamp" />
            <column name="updated_by" type="string" />
            <column name="updated_at" type="timestamp" />
        </loadData>
    </changeSet>

    <changeSet id="load-data-role-permissions" author="CanhPC">
        <loadData file="liquibase/data/role_permissions.csv" separator=";" tableName="role_permissions">
            <column name="role_code" type="string" />
            <column name="permission_code" type="string" />
            <column name="created_by" type="string" />
            <column name="created_at" type="timestamp" />
            <column name="updated_by" type="string" />
            <column name="updated_at" type="timestamp" />
        </loadData>
    </changeSet>

</databaseChangeLog>

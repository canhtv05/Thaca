<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="load-data-cms" author="CanhPC">
        <loadData file="liquibase/data/plan.csv" separator=";" tableName="plans" schemaName="cms">
            <column name="id" type="NUMERIC"/>
            <column name="code" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="type" type="STRING"/>
            <column name="max_users" type="NUMERIC"/>
            <column name="status" type="STRING"/>
            <column name="created_by" type="STRING"/>
            <column name="created_at" type="DATE"/>
        </loadData>

        <loadData file="liquibase/data/tenant.csv" separator=";" tableName="tenants" schemaName="cms">
            <column name="id" type="NUMERIC"/>
            <column name="code" type="STRING"/>
            <column name="name" type="STRING"/>
            <column name="domain" type="STRING"/>
            <column name="status" type="STRING"/>
            <column name="plan_id" type="NUMERIC"/>
            <column name="created_by" type="STRING"/>
            <column name="created_at" type="DATE"/>
            <column name="updated_by" type="STRING"/>
            <column name="updated_at" type="DATE"/>
        </loadData>
    </changeSet>

</databaseChangeLog>

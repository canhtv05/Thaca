<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

  <changeSet id="1" author="CanhPC">
    <createTable tableName="mail_configs" schemaName="notification">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="tenant_id" type="VARCHAR(255)"/>
      <column name="config_code" type="VARCHAR(255)"/>
      <column name="description" type="VARCHAR(255)"/>
      <column name="host" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="port" type="INT">
        <constraints nullable="false"/>
      </column>
      <column name="username" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="password" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="is_auth" type="BOOLEAN" defaultValueBoolean="true"/>
      <column name="is_starttls" type="BOOLEAN" defaultValueBoolean="true"/>
      <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"/>

      <column name="created_by" type="VARCHAR(255)"/>
      <column name="updated_by" type="VARCHAR(255)"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>

    <createIndex tableName="mail_configs" indexName="idx_mail_configs_tenant">
      <column name="tenant_id"/>
    </createIndex>

  </changeSet>

  <changeSet id="2" author="CanhPC">
    <addColumn tableName="mail_configs" schemaName="notification">
      <column name="from_name" type="VARCHAR(255)"/>
      <column name="from_email" type="VARCHAR(255)"/>
      <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
    </addColumn>

    <createIndex tableName="mail_configs" indexName="idx_mail_configs_code" schemaName="notification">
      <column name="config_code"/>
    </createIndex>
  </changeSet>

  <changeSet id="3" author="CanhPC">
    <createTable tableName="notification_routing_configs" schemaName="notification">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="tenant_id" type="VARCHAR(255)"/>
      <column name="notification_type" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="channel" type="VARCHAR(50)">
        <constraints nullable="false"/>
      </column>
      <column name="mail_config_code" type="VARCHAR(255)"/>
      <column name="template_code" type="VARCHAR(255)"/>
      <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
      <column name="priority" type="INT" defaultValueNumeric="100"/>
      <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>

      <column name="created_by" type="VARCHAR(255)"/>
      <column name="updated_by" type="VARCHAR(255)"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>

    <createIndex tableName="notification_routing_configs" indexName="idx_noti_route_tenant_type_channel">
      <column name="tenant_id"/>
      <column name="notification_type"/>
      <column name="channel"/>
    </createIndex>

    <createIndex tableName="notification_routing_configs" indexName="idx_noti_route_default">
      <column name="tenant_id"/>
      <column name="channel"/>
      <column name="is_default"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
